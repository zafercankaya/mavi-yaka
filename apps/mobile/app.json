{
  "expo": {
    "name": "Kampanya Sepeti",
    "slug": "kampanya-sepeti",
    "scheme": "kampanya",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "locales": {
      "tr": "./locales/tr.json",
      "en": "./locales/en.json",
      "de": "./locales/de.json",
      "fr": "./locales/fr.json",
      "it": "./locales/it.json",
      "pt": "./locales/pt.json",
      "es": "./locales/es.json",
      "id": "./locales/id.json",
      "ru": "./locales/ru.json",
      "ja": "./locales/ja.json",
      "th": "./locales/th.json",
      "ar": "./locales/ar.json",
      "ko": "./locales/ko.json",
      "vi": "./locales/vi.json",
      "pl": "./locales/pl.json",
      "ms": "./locales/ms.json",
      "nl": "./locales/nl.json",
      "sv": "./locales/sv.json",
      "ur": "./locales/ur.json"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.kampanyasepeti.app",
      "buildNumber": "6",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:kampanya-sepeti-api-3c9f.onrender.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": [
              "CA92.1"
            ]
          }
        ]
      }
    },
    "android": {
      "package": "com.kampanyasepeti.app",
      "versionCode": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-web-browser",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "enableProguardInReleaseBuilds": false,
            "lint": {
              "checkReleaseBuilds": false
            }
          }
        }
      ],
      "expo-localization",
      "./plugins/disable-lint",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4200780317005480~8939916783",
          "iosAppId": "ca-app-pub-4200780317005480~5000671778"
        }
      ]
    ],
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "13f0c4ed-963d-40ec-8490-e36784a325ae"
      }
    },
    "owner": "zafer77can"
  }
}
