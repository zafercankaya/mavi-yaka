generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────

model User {
  id           String                  @id @default(uuid())
  email        String                  @unique
  passwordHash String?                 @map("password_hash")
  displayName  String?                 @map("display_name")
  role         UserRole                @default(USER)
  authProvider AuthProvider            @default(EMAIL) @map("auth_provider")
  providerId   String?                 @map("provider_id")
  market       Market                  @default(TR)
  referralCode String?                 @unique @map("referral_code")
  referredById String?                 @map("referred_by_id")
  referredBy   User?                   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]                  @relation("UserReferrals")
  fcmTokens           FcmToken[]
  followedCompanies   FollowedCompany[]
  followedSectors     FollowedSector[]
  savedJobs           SavedJob[]
  jobAlerts           JobAlert[]
  subscription        Subscription?
  notifPref           NotificationPreference?
  notifications       Notification[]
  preferredSectors    Sector[]
  preferredJobTypes   JobType[]
  preferredLocations  Json?              @map("preferred_locations")
  lastActivityAt      DateTime?          @map("last_activity_at")
  createdAt    DateTime                @default(now()) @map("created_at")
  updatedAt    DateTime                @updatedAt @map("updated_at")

  @@unique([authProvider, providerId])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
}

model FcmToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  platform  Platform
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("fcm_tokens")
}

enum Platform {
  IOS
  ANDROID
}

// ─── Subscriptions ───────────────────────────────────────

model SubscriptionPlan {
  id                 String         @id @default(uuid())
  name               String
  market             Market         @default(TR)
  currency           String         @default("TRY") @db.VarChar(3)
  appleProductId     String?        @map("apple_product_id")
  googleProductId    String?        @map("google_product_id")
  priceMonthly       Decimal?       @map("price_monthly") @db.Decimal(10, 2)
  priceYearly        Decimal?       @map("price_yearly") @db.Decimal(10, 2)
  maxCompanyFollows  Int            @default(5) @map("max_company_follows")
  maxSavedJobs       Int            @default(20) @map("max_saved_jobs")
  maxAlerts          Int            @default(1) @map("max_alerts")
  dailyViewLimit     Int            @default(20) @map("daily_view_limit")
  hasAdvancedFilter  Boolean        @default(false) @map("has_advanced_filter")
  adFree             Boolean        @default(false) @map("ad_free")
  weeklyDigest       Boolean        @default(false) @map("weekly_digest")
  isActive           Boolean        @default(true) @map("is_active")
  subscriptions      Subscription[]
  createdAt          DateTime       @default(now()) @map("created_at")

  @@unique([name, market])
  @@map("subscription_plans")
}

model Subscription {
  id               String           @id @default(uuid())
  userId           String           @unique @map("user_id")
  planId           String           @map("plan_id")
  status           SubStatus        @default(ACTIVE)
  provider         PaymentProvider
  providerSubId    String?          @map("provider_sub_id")
  currentPeriodEnd DateTime?        @map("current_period_end")
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  @@map("subscriptions")
}

enum SubStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  GRACE_PERIOD
}

enum PaymentProvider {
  APPLE
  GOOGLE
  REFERRAL
}

// ─── Market ──────────────────────────────────────────────

enum Market {
  TR
  US
  DE
  UK
  IN
  BR
  ID
  RU
  MX
  JP
  PH
  TH
  CA
  AU
  FR
  IT
  ES
  EG
  SA
  KR
  AR
  AE
  VN
  PL
  MY
  CO
  ZA
  PT
  NL
  PK
  SE
}

// ─── Sectors & Job Enums ─────────────────────────────────

enum Sector {
  LOGISTICS_TRANSPORTATION
  MANUFACTURING
  RETAIL
  CONSTRUCTION
  FOOD_BEVERAGE
  AUTOMOTIVE
  TEXTILE
  MINING_ENERGY
  HEALTHCARE
  HOSPITALITY_TOURISM
  AGRICULTURE
  SECURITY_SERVICES
  FACILITY_MANAGEMENT
  METAL_STEEL
  CHEMICALS_PLASTICS
  ECOMMERCE_CARGO
  TELECOMMUNICATIONS
  OTHER
}

enum JobType {
  FULL_TIME
  PART_TIME
  DAILY
  SEASONAL
  INTERNSHIP
  CONTRACT
}

enum WorkMode {
  ON_SITE
  REMOTE
  HYBRID
}

enum ExperienceLevel {
  NONE
  ENTRY
  MID
  SENIOR
}

enum SalaryPeriod {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum SourceType {
  GOVERNMENT
  JOB_PLATFORM
  COMPANY_CAREER
}

enum JobStatus {
  ACTIVE
  EXPIRED
  REMOVED
}

// ─── Companies (was Brand) ──────────────────────────────

model Company {
  id            String        @id @default(uuid())
  name          String
  slug          String
  logoUrl       String?       @map("logo_url")
  websiteUrl    String?       @map("website_url")
  sector        Sector        @default(OTHER)
  market        Market        @default(TR)
  description   String?       @db.Text
  employeeCount String?       @map("employee_count")
  isActive      Boolean       @default(true) @map("is_active")
  jobListings   JobListing[]
  sources       CrawlSource[]
  followers     FollowedCompany[]
  createdAt     DateTime      @default(now()) @map("created_at")

  @@unique([slug, market])
  @@index([market, isActive])
  @@map("companies")
}

// ─── Job Listings (was Campaign) ─────────────────────────

model JobListing {
  id              String           @id @default(uuid())
  title           String
  slug            String
  companyId       String           @map("company_id")
  sourceUrl       String           @map("source_url")
  canonicalUrl    String?          @map("canonical_url")

  // Location
  country         Market
  state           String?
  city            String?
  latitude        Float?
  longitude       Float?

  // Job details
  sector          Sector           @default(OTHER)
  jobType         JobType          @default(FULL_TIME) @map("job_type")
  workMode        WorkMode         @default(ON_SITE) @map("work_mode")

  // Salary
  salaryMin       Decimal?         @map("salary_min") @db.Decimal(12, 2)
  salaryMax       Decimal?         @map("salary_max") @db.Decimal(12, 2)
  salaryCurrency  String?          @map("salary_currency") @db.VarChar(3)
  salaryPeriod    SalaryPeriod?    @map("salary_period")

  // Details
  experienceLevel ExperienceLevel? @map("experience_level")
  description     String?          @db.Text
  requirements    String?          @db.Text
  benefits        String?          @db.Text
  summary         String?          @db.Text
  deadline        DateTime?
  postedDate      DateTime?        @map("posted_date")
  imageUrl        String?          @map("image_url")

  // Status & tracking
  status          JobStatus        @default(ACTIVE)
  lastSeenAt      DateTime         @default(now()) @map("last_seen_at")
  viewCount       Int              @default(0) @map("view_count")
  clickCount      Int              @default(0) @map("click_count")
  fingerprint     String?

  // Relations
  sourceId        String?          @map("source_id")
  company         Company          @relation(fields: [companyId], references: [id])
  source          CrawlSource?     @relation(fields: [sourceId], references: [id])
  savedBy         SavedJob[]

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  @@unique([fingerprint])
  @@index([country, status, createdAt(sort: Desc)])
  @@index([country, sector, status])
  @@index([country, state, city, status])
  @@index([companyId, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([lastSeenAt])
  @@index([sourceId])
  @@map("job_listings")
}

// ─── Locations ──────────────────────────────────────────

model Location {
  id         String  @id @default(uuid())
  country    Market
  state      String
  city       String?
  latitude   Float
  longitude  Float
  population Int?
  nameLocal  String  @map("name_local")
  nameEn     String  @map("name_en")

  @@unique([country, state, city])
  @@index([country, state])
  @@index([country])
  @@map("locations")
}

// ─── Follows ─────────────────────────────────────────────

model FollowedCompany {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  isFrozen  Boolean  @default(false) @map("is_frozen")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, companyId])
  @@map("followed_companies")
}

model FollowedSector {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  sector    Sector
  market    Market
  isFrozen  Boolean  @default(false) @map("is_frozen")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, sector, market])
  @@map("followed_sectors")
}

// ─── Saved Jobs (was Favorite) ──────────────────────────

model SavedJob {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  jobListingId String     @map("job_listing_id")
  isFrozen     Boolean    @default(false) @map("is_frozen")
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobListing   JobListing @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([userId, jobListingId])
  @@map("saved_jobs")
}

// ─── Job Alerts ─────────────────────────────────────────

model JobAlert {
  id             String           @id @default(uuid())
  userId         String           @map("user_id")
  name           String
  country        Market
  state          String?
  city           String?
  sector         Sector?
  jobType        JobType?         @map("job_type")
  workMode       WorkMode?        @map("work_mode")
  keywords       String?
  salaryMin      Decimal?         @map("salary_min") @db.Decimal(12, 2)
  isActive       Boolean          @default(true) @map("is_active")
  lastNotifiedAt DateTime?        @map("last_notified_at")
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@map("job_alerts")
}

// ─── Notifications ──────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  enabled   Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

// ─── Crawling ────────────────────────────────────────────

model CrawlSource {
  id                String      @id @default(uuid())
  companyId         String      @map("company_id")
  name              String
  type              SourceType  @default(COMPANY_CAREER)
  crawlMethod       CrawlMethod @map("crawl_method")
  seedUrls          String[]    @map("seed_urls")
  maxDepth          Int         @default(2) @map("max_depth")
  selectors         Json?
  detailSelectors   Json?       @map("detail_selectors")
  schedule          String      @default("0 3 * * *")
  agingDays         Int         @default(14) @map("aging_days")
  market            Market      @default(TR)
  isActive          Boolean     @default(true) @map("is_active")
  lastCrawledAt     DateTime?   @map("last_crawled_at")
  discoveredApiUrl  String?     @map("discovered_api_url")
  company           Company     @relation(fields: [companyId], references: [id])
  jobListings       JobListing[]
  crawlLogs         CrawlLog[]
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@index([market, isActive])
  @@map("crawl_sources")
}

enum CrawlMethod {
  HTML
  API
  RSS
  STRUCTURED_DATA
}

model CrawlLog {
  id             String      @id @default(uuid())
  sourceId       String      @map("source_id")
  status         CrawlStatus
  jobsFound      Int         @default(0) @map("jobs_found")
  jobsNew        Int         @default(0) @map("jobs_new")
  jobsUpdated    Int         @default(0) @map("jobs_updated")
  errorMessage   String?     @map("error_message") @db.Text
  durationMs     Int?        @map("duration_ms")
  source         CrawlSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now()) @map("created_at")

  @@index([sourceId, createdAt(sort: Desc)])
  @@map("crawl_logs")
}

enum CrawlStatus {
  RUNNING
  SUCCESS
  PARTIAL
  FAILED
}

// ─── App Config (key-value) ────────────────────────────────

model AppConfig {
  key       String   @id
  value     String
  label     String?
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("app_config")
}

// ─── Daily Reports ────────────────────────────────────────

model DailyReport {
  id             String   @id @default(uuid())
  date           DateTime @unique @map("report_date") @db.Date

  // Crawl stats
  totalSources   Int      @default(0) @map("total_sources")
  sourcesSuccess Int      @default(0) @map("sources_success")
  sourcesFailed  Int      @default(0) @map("sources_failed")
  jobsFound      Int      @default(0) @map("jobs_found")
  jobsNew        Int      @default(0) @map("jobs_new")
  jobsUpdated    Int      @default(0) @map("jobs_updated")
  jobsExpired    Int      @default(0) @map("jobs_expired")
  crawlDurationMs Int     @default(0) @map("crawl_duration_ms")

  // Maintenance stats
  maintenanceActions Int  @default(0) @map("maintenance_actions")
  maintenanceErrors  Int  @default(0) @map("maintenance_errors")

  // Per-market detail
  marketStats    Json     @default("[]") @map("market_stats")
  maintenanceTasks Json   @default("[]") @map("maintenance_tasks")

  createdAt      DateTime @default(now()) @map("created_at")

  @@index([date(sort: Desc)])
  @@map("daily_reports")
}

// ─── Analytics ─────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  userId    String?  @map("user_id")
  params    Json     @default("{}")
  timestamp DateTime @default(now())

  @@index([event, timestamp])
  @@index([userId])
  @@map("analytics_events")
}
